      "resultState": "聊天界面(已发送)",
      "params": [],
      "steps": [
        {"action": "click", "coordinate": [900, 860]}
      ]
    },
    {
      "id": "wechat_moments_nav",
      "name": "微信-进入朋友圈",
      "appPackage": "com.tencent.mm",
