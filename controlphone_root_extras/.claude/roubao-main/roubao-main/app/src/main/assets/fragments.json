{
  "fragments": [
    {
      "id": "wechat_open",
      "name": "微信-打开应用",
      "appPackage": "com.tencent.mm",
      "appName": "微信",
      "category": "open",
      "precondition": "任意",
      "resultState": "微信主页",
      "params": [],
      "steps": [
        {"action": "open_app", "text": "微信"},
        {"action": "wait", "duration": 2}
      ]
    },
    {
      "id": "wechat_search_contact",
      "name": "微信-搜索联系人",
