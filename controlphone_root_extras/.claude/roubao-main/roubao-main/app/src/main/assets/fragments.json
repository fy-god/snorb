  "templates": [
    {
      "id": "wechat_send_message",
      "name": "发微信消息",
      "intentPatterns": ["给X发Y", "发微信给X Y"],
      "appMatcher": "com.tencent.mm",
      "fragments": ["wechat_open", "wechat_search_contact", "wechat_type_message", "wechat_send"],
      "paramMapping": {"X": "contact", "Y": "message"}
    },
    {
      "id": "wechat_search",
      "name": "微信搜索",
      "intentPatterns": ["微信搜X"],
      "appMatcher": "com.tencent.mm",
      "fragments": ["wechat_open", "wechat_search_contact"],
      "paramMapping": {"X": "contact"}
    },
    {
      "id": "wechat_moments",
      "name": "微信朋友圈",
      "intentPatterns": ["朋友圈"],
      "appMatcher": "com.tencent.mm",
      "fragments": ["wechat_open", "wechat_moments_nav"],
      "paramMapping": {}
    },
    {
      "id": "browser_search",
      "name": "浏览器搜索",
      "intentPatterns": ["搜X", "百度X"],
      "appMatcher": "com.android.browser",
      "fragments": ["browser_open", "browser_search_box"],
      "paramMapping": {"X": "query"}
    },
    {
      "id": "douyin_search",
      "name": "抖音搜索",
      "intentPatterns": ["抖音搜X"],
      "appMatcher": "com.ss.android.ugc.aweme",
      "fragments": ["douyin_open", "douyin_search"],
      "paramMapping": {"X": "query"}
    },
    {
      "id": "taobao_open",
      "name": "打开淘宝",
      "intentPatterns": ["淘宝"],
      "appMatcher": "com.taobao.taobao",
      "fragments": ["taobao_open"],
      "paramMapping": {}
    },
    {
      "id": "settings_open",
      "name": "打开设置项",
      "intentPatterns": ["设置X"],
      "appMatcher": "com.android.settings",
      "fragments": ["settings_open", "settings_search_item"],
      "paramMapping": {"X": "item"}
    },
    {
      "id": "alipay_scan",
      "name": "支付宝扫码",
      "intentPatterns": ["扫码", "扫一扫"],
      "appMatcher": "com.eg.android.AlipayGphone",
      "fragments": ["alipay_open", "alipay_scan_btn"],
      "paramMapping": {}
    },
    {
      "id": "open_app_only",
      "name": "打开应用",
      "intentPatterns": ["打开X"],
      "appMatcher": "_any_",
      "fragments": ["home_button"],
      "paramMapping": {}
    }
  ]
}
