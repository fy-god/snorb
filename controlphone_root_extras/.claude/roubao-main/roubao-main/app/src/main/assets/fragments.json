      "resultState": "聊天界面(已输入)",
      "params": ["message"],
      "steps": [
        {"action": "click", "coordinate": [500, 860]},
        {"action": "wait", "duration": 0.5},
        {"action": "type", "text": "{message}"}
      ]
    },
    {
      "id": "wechat_send",
