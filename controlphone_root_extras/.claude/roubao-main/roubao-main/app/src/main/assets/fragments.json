      "appName": "微信",
      "category": "search",
      "precondition": "微信主页",
      "resultState": "聊天界面",
      "params": ["contact"],
      "steps": [
        {"action": "click", "coordinate": [500, 190]},
        {"action": "wait", "duration": 1},
        {"action": "type", "text": "{contact}"},
        {"action": "wait", "duration": 1},
        {"action": "click", "coordinate": [500, 380]}
      ]
    },
    {
      "id": "wechat_type_message",
      "name": "微信-输入消息",
