      "precondition": "微信主页",
      "resultState": "朋友圈",
      "params": [],
      "steps": [
        {"action": "click", "coordinate": [330, 940]},
        {"action": "wait", "duration": 0.5},
        {"action": "click", "coordinate": [500, 780]}
      ]
    },
    {
      "id": "browser_open",
