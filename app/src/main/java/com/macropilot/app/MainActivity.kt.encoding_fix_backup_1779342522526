    private fun runSkillFactorySelfTestFromUi() {
        factoryLiveStart(factoryTargetPackage, "Factory иҮӘжЈҖ", "жӯЈеңЁжЈҖжҹҘпјҡAI жөҒзЁӢж§ҪдҪҚгҖҒжЁЎжқҝж”№еҶҷгҖҒJSON жӢјиЈ…гҖҒAppUI еӣҫи°ұгҖҒdry-run е’ҢеӯҳеӮЁжІ»зҗҶгҖ?)
        Thread {
            val report = SkillFactorySelfTest(this).run()
            val checks = report.optJSONArray("checks") ?: JSONArray()
            for (index in 0 until checks.length()) {
                val check = checks.optJSONObject(index) ?: continue
                factoryLiveStep(
                    title = "иҮӘжЈҖпј?{check.optString("name")}",
                    status = if (check.optBoolean("passed")) "SUCCESS" else "FAILED",
                    message = check.optString("message").take(260)
                )
            }
