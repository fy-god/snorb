            return
        }
        val scopedApps = scopeApps(apps, modules, skills, jsonSkillPackages)
        val filteredApps = filterApps(scopedApps)

        compactHeader("жЁЎеқ—", "е·ІиҜ»еҸ?${apps.size} дёӘеә”з”ЁпјҢеҪ“еүҚжҳҫзӨә ${filteredApps.size} дё?)
