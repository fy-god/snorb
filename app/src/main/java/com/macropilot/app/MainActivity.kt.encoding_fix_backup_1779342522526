            appFilter = filterInput.text?.toString().orEmpty().trim()
            renderApps()
        }, LinearLayout.LayoutParams(dp(76), dp(40)))
        content.addView(filterRow, margins(top = 12))

        val toolbar = horizontal()
        toolbar.addView(actionButton("+ и®ҫзҪ®зӨәдҫӢ", primary = true) {
            seedAllSettingsSkills()
            cachedApps = null
            toast("е·Іж·»еҠ и®ҫзҪ®зӨәдҫӢиғҪеҠ?)
            renderApps()
        }, LinearLayout.LayoutParams(0, dp(40), 1f))
        toolbar.addView(space(10, 1))
        toolbar.addView(actionButton("еҲ·ж–°") {
            cachedApps = null
            renderApps()
        }, LinearLayout.LayoutParams(0, dp(40), 1f))
        content.addView(toolbar, margins(top = 12, bottom = 6))

        val moduleOwners = modules.flatMap { module ->
            (listOf(module.packageName) + module.packageAliases).map { alias -> alias to module.packageName }
        }.toMap()
        val jsonSkillsByPackage = jsonSkillFiles.groupBy { skillJsonPackage(it).orEmpty() }

        val scroll = ScrollView(this).apply { isFillViewport = false }
        val list = LinearLayout(this).apply { orientation = LinearLayout.VERTICAL }
        scroll.addView(list)
        if (filteredApps.isEmpty()) {
            list.addView(emptyState("жІЎжңүеҢ№й…Қзҡ„еә”з”?))
        }
        filteredApps.forEach { app ->
            val ownerPackage = moduleOwners[app.packageName]
            val ownerModule = modules.firstOrNull { it.packageName == ownerPackage || it.packageName == app.packageName }
            val appSkills = skills.filter { it.packageName == app.packageName || it.packageName == ownerPackage }
            val appJsonSkills = (jsonSkillsByPackage[app.packageName].orEmpty() + jsonSkillsByPackage[ownerPackage].orEmpty())
                .distinctBy { it.absolutePath }
            list.addView(appRow(app, ownerModule, appSkills, appJsonSkills))
        }
        content.addView(scroll, LinearLayout.LayoutParams(LinearLayout.LayoutParams.MATCH_PARENT, 0, 1f))
    }

