    private fun inferPackageForUiCommand(command: String): String {
        return when {
            command.contains("е“”е“©") ||
                command.contains("Bз«?, ignoreCase = true) ||
                command.contains("bilibili", ignoreCase = true) -> SkillJsonRuleGenerator.BILIBILI_PACKAGE
            command.contains("еҫ®дҝЎ") ||
                command.contains("wechat", ignoreCase = true) -> SkillJsonRuleGenerator.WECHAT_PACKAGE
            command.contains("е°Ҹзәўд№?) ||
                command.contains("xiaohongshu", ignoreCase = true) ||
                command.contains("xhs", ignoreCase = true) -> SkillJsonRuleGenerator.XIAOHONGSHU_PACKAGE
            Regex("[a-zA-Z][a-zA-Z0-9_]*(\\.[a-zA-Z0-9_]+)+").find(command) != null ->
                Regex("[a-zA-Z][a-zA-Z0-9_]*(\\.[a-zA-Z0-9_]+)+").find(command)?.value.orEmpty()
            else -> findInstalledPackageForCommandClean(command).orEmpty()
        }
    }

    private fun defaultThirdPartyTaskCommandClean(): String {
        val apps = installedThirdPartyAppLabelsClean()
        val preferredNames = listOf("е°Ҹзәўд№?, "жҠ–йҹі", "ж·ҳе®қ", "дә¬дёң", "зҹҘд№Һ", "еҫ®еҚҡ", "й«ҳеҫ·", "зҷҫеәҰ", "й…·е®ү", "QQ", "е“”е“©")
        val chosen = preferredNames.firstNotNullOfOrNull { name ->
            apps.firstOrNull { (label, _) -> label.contains(name, ignoreCase = true) }
        } ?: apps.firstOrNull { (_, appPackage) ->
            appPackage != this@MainActivity.packageName
        } ?: apps.firstOrNull()
        val label = chosen?.first ?: "е“”е“©е“”е“©"
        return "жү“ејҖ${label}жҗңзҙўзҢ«е’ҢиҖҒйј "
    }

    private fun findInstalledPackageForCommandClean(command: String): String? {
        val normalized = command.lowercase()
        return installedThirdPartyAppLabelsClean()
            .firstOrNull { (label, packageName) ->
                appLabelMatchesCommandClean(normalized, label, packageName)
            }
            ?.second
    }

    private fun appLabelMatchesCommandClean(normalizedCommand: String, label: String, packageName: String): Boolean {
        val compact = label.trim().lowercase()
        if (compact.isBlank()) return false
        if (normalizedCommand.contains(packageName.lowercase())) return true
        if (compact.length >= 2 && normalizedCommand.contains(compact)) return true
        val latinTokens = Regex("[a-z0-9][a-z0-9._-]{2,}")
            .findAll(compact)
            .map { it.value }
            .toList()
        return latinTokens.any { token -> normalizedCommand.contains(token) }
    }

    private fun installedThirdPartyAppLabelsClean(): List<Pair<String, String>> {
        return runCatching {
            packageManager.getInstalledApplications(0)
                .asSequence()
                .filter { app -> app.flags and ApplicationInfo.FLAG_SYSTEM == 0 }
                .filter { app -> packageManager.getLaunchIntentForPackage(app.packageName) != null }
                .map { app -> packageManager.getApplicationLabel(app).toString() to app.packageName }
                .filter { (label, appPackage) ->
                    label.isNotBlank() && appPackage != this@MainActivity.packageName
                }
                .distinctBy { it.second }
                .toList()
        }.getOrDefault(emptyList())
    }

    private fun extractBilibiliQueryFromInstruction(raw: String): String {
        val trimmed = raw.trim()
        if (trimmed.isBlank() || looksLikeMojibake(trimmed)) return "зҢ«е’ҢиҖҒйј "
        val markers = listOf("еңЁе“”е“©е“”е“©жҗңзҙ?, "е“”е“©е“”е“©жҗңзҙў", "еңЁBз«ҷжҗңзҙ?, "Bз«ҷжҗңзҙ?, "еңЁbilibiliжҗңзҙў", "bilibiliжҗңзҙў", "жҗңзҙў", "жҗ?)
        val explicit = markers.firstNotNullOfOrNull { marker ->
            trimmed.substringAfter(marker, missingDelimiterValue = "")
                .trim()
                .takeIf { it.isNotBlank() && it != trimmed }
        }
        return (explicit ?: trimmed)
            .replace("е“”е“©е“”е“©", "")
            .replace("е“”е“©", "")
            .replace("Bз«?, "")
            .replace("bilibili", "", ignoreCase = true)
            .replace("жҗңзҙў", "")
            .trim()
            .ifBlank { "зҢ«е’ҢиҖҒйј " }
    }

