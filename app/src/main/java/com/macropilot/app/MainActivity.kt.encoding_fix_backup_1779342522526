    private fun jsonSkillCard(file: File, compact: Boolean = false): View {
        val json = runCatching { JSONObject(file.readText()) }.getOrNull()
        val id = json?.optString("id")?.takeIf { it.isNotBlank() } ?: file.nameWithoutExtension
        val expanded = expandedSkillId == "json:$id"
        val card = LinearLayout(this).apply {
            orientation = LinearLayout.VERTICAL
            background = rounded(if (compact) COLOR_PANEL else COLOR_CARD, dp(8), COLOR_STROKE)
            setPadding(dp(14), dp(10), dp(14), dp(10))
            isClickable = true
            isFocusable = true
            setOnClickListener {
                expandedSkillId = if (expanded) null else "json:$id"
                renderCurrentTab()
            }
        }
        val top = horizontal()
        val names = LinearLayout(this).apply { orientation = LinearLayout.VERTICAL }
        val kind = json?.optString("kind", "skill_json") ?: "skill_json"
        val implementsName = json?.optString("implements", "") ?: ""
        val rawName = json?.optString("name")?.takeIf { it.isNotBlank() }
        val displayName = factorySkillDisplayName(id, rawName)
        names.addView(label(displayName, if (compact) 14f else 16f, COLOR_TEXT, bold = true, maxLines = 1))
        val kindLine = if (implementsName.isBlank()) {
            "$id В· ${factoryKindText(kind)}"
        } else {
            "$id В· ${factoryKindText(kind)} В· ${factoryImplementsText(implementsName)}"
        }
        names.addView(label(kindLine, 12f, COLOR_MUTED, maxLines = 1))
        top.addView(names, LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f))
        val status = json?.optString("status", "FILE") ?: "FILE"
        top.addView(pill(factoryStatusText(status), active = factoryStatusActive(status)))
        card.addView(top)
        if (expanded) {
            card.addView(jsonSkillDetails(file, json))
