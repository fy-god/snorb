    private fun syncFactoryLiveFromLatestFlowIfIdle(store: FactorySkillJsonStore) {
        if (factoryLiveStatus == "RUNNING") return
        val latestFlow = store.listFlowReports(null, 1).firstOrNull() ?: return
        if (factoryLiveReportName == latestFlow.name && factoryLiveEvents.isNotEmpty()) return
        val flowJson = runCatching { JSONObject(latestFlow.readText()) }.getOrNull() ?: return
        val steps = flowJson.optJSONArray("steps")
        val status = flowJson.optString("status").ifBlank { "INFO" }
        val appPackage = flowJson.optString("appPackage").ifBlank { factoryTargetPackage }
        val query = flowJson.optString("query").ifBlank { flowJson.optString("instruction") }
        val lastStep = steps?.optJSONObject((steps.length() - 1).coerceAtLeast(0))

        if (appPackage.isNotBlank()) {
            factoryTargetPackage = appPackage
            factoryLivePackage = appPackage
        }
        if (query.isNotBlank() && !looksLikeMojibake(query)) {
            factoryInstruction = query
        }
        factoryLiveStatus = status
        factoryLiveTitle = "\u6700\u8fd1\u624b\u673a\u7aef\u6307\u4ee4\u7ed3\u679c"
        factoryLiveMessage = lastStep?.optString("message")
            ?.takeIf { it.isNotBlank() }
            ?: "\u6700\u8fd1\u4e00\u6b21\u624b\u673a\u7aef\u6d41\u6c34\u7ebf\u5df2\u5199\u5165\u62a5\u544a\u3002"
        factoryLivePath = flowJson.optString("reportFile").ifBlank { latestFlow.absolutePath }
        factoryLiveReportName = latestFlow.name
        factoryLiveEvents = if (steps == null || steps.length() == 0) {
            emptyList()
        } else {
            val events = mutableListOf<FactoryLiveEvent>()
            val first = (steps.length() - 40).coerceAtLeast(0)
            for (index in steps.length() - 1 downTo first) {
                val step = steps.optJSONObject(index) ?: continue
                events.add(
                    FactoryLiveEvent(
                        timestamp = step.optLong("timestamp", latestFlow.lastModified()),
                        title = step.optString("title").ifBlank { "\u6d41\u6c34\u7ebf\u6b65\u9aa4" },
                        status = step.optString("status").ifBlank { "INFO" },
                        message = step.optString("message"),
                        path = step.optString("path").takeIf { it.isNotBlank() && it != "null" }
                    )
                )
            }
            events
        }
    }

