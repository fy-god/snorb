        if (instruction.isBlank()) {
            factoryLiveDone("и§ЈжһҗжҢҮд»Ө", "FAILED", "иҜ·е…Ҳиҫ“е…Ҙз”ЁжҲ·жҢҮд»ӨгҖ?)
