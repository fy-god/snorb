    private fun aiConfigWarnings(
        config: AiAssistConfig,
        provider: AiProvider,
        endpoint: String,
        model: String
    ): List<String> {
        val warnings = mutableListOf<String>()
        val lowerEndpoint = endpoint.lowercase()
        val lowerModel = model.lowercase()
        if (lowerEndpoint.contains("deepseek.com") && provider == AiProvider.DASHSCOPE_COMPAT_CHAT) {
            warnings += "й…ҚзҪ®еҶІзӘҒпјҡDeepSeek зҪ‘еқҖеә”дҪҝз”?OPENAI_COMPAT_CHATпјҢдёҚжҳ?DASHSCOPE_COMPAT_CHATгҖ?
        }
        if (lowerEndpoint.contains("dashscope") && provider != AiProvider.DASHSCOPE_COMPAT_CHAT) {
            warnings += "й…ҚзҪ®еҶІзӘҒпјҡйҖҡд№ү DashScope зҪ‘еқҖеә”дҪҝз”?DASHSCOPE_COMPAT_CHATгҖ?
        }
        if (lowerEndpoint.contains("dashscope") && !lowerModel.contains("vl")) {
            warnings += "жЁЎеһӢеҗҚжҸҗйҶ’пјҡжүӢжңәз•ҢйқўиҜҶеӣҫе»әи®®дҪҝз”Ё qwen3-vl-flash жҲ–е…¶д»?VL жЁЎеһӢгҖ?
        }
        if (config.enabled && !config.apiKeyPresent) {
            warnings += "иҝҳжІЎжңүдҝқеӯ?API KeyпјҢжүҖд»?AI иҜ·жұӮдёҚдјҡзңҹжӯЈеҸ‘еҮәеҺ»гҖ?
        }
        return warnings
    }

    private fun aiConfigDiagnosticsText(config: AiAssistConfig, warnings: List<String>): String {
        val base = when {
