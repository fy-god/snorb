    private fun runFactoryVisibleSmokeTestFromUi(packageName: String) {
        factoryLiveStart(packageName, "дёҖй”®е®үе…ЁжөӢиҜ•й“ҫи·?, "ејҖе§ӢдёІиө·еҖҷйҖ?JSON -> dry-run -> йў„и§Ҳй…ҚзҪ® -> жөӢиҜ• -> жҷӢзә§ -> Runtime и°ғз”ЁгҖ?)
        Thread {
            val store = FactorySkillJsonStore(this)
            val steps = JSONArray()
            val startedAt = System.currentTimeMillis()
            var finalStatus = "SUCCESS"
            var previewConfigFile: File? = null
            var assemblyReportFile: File? = null
            var runtimeConfigFile: File? = null
            var runtimeRunReportFile: File? = null
            var testedSkillId = ""

            fun addStep(name: String, status: String, message: String, extra: JSONObject? = null) {
                if (status.startsWith("FAILED")) finalStatus = "FAILED"
                val item = JSONObject()
                    .put("name", name)
                    .put("status", status)
                    .put("message", message)
                    .put("timestamp", System.currentTimeMillis())
                if (extra != null) item.put("extra", extra)
                steps.put(item)
                factoryLiveStep(name, status, message)
            }

            try {
                var candidateFiles = store.listSkillFiles(packageName, 1000)
                if (candidateFiles.isEmpty() && packageName == SkillJsonRuleGenerator.WECHAT_PACKAGE) {
                    candidateFiles = SkillJsonRuleGenerator().generateWechatCurrentChat()
                        .map { skill -> store.saveSkill(skill.getString("appPackage"), skill) }
                    addStep("з”ҹжҲҗеҖҷйҖ?Skill JSON", "SUCCESS", "е·Із”ҹжҲ?${candidateFiles.size} дёӘеҫ®дҝЎз»ҶзІ’еәҰеҖҷйҖ?)
                } else {
                    addStep("иҜ»еҸ–еҖҷйҖ?Skill JSON", "SUCCESS", "жүҫеҲ° ${candidateFiles.size} дёӘеҖҷйҖүж–Үд»?)
                }

                if (candidateFiles.isEmpty()) {
                    addStep("еҒңжӯў", "FAILED_NO_CANDIDATE", "еҪ“еүҚеә”з”ЁиҝҳжІЎжңүеҖҷйҖ?skill JSON")
                } else {
                    val knownIds = store.listSkillFiles().mapNotNull { file ->
                        runCatching { JSONObject(file.readText()).optString("id").takeIf { it.isNotBlank() } }.getOrNull()
                    }.toSet()
                    val dryTargets = candidateFiles.filter { file ->
                        runCatching { JSONObject(file.readText()).optString("status") != "APPROVED" }.getOrDefault(false)
                    }
                    val dryRunEngine = SkillJsonDryRunEngine()
                    var dryPassed = 0
                    dryTargets.forEach { file ->
                        val skill = runCatching { JSONObject(file.readText()) }.getOrNull() ?: return@forEach
                        val report = dryRunEngine.dryRun(skill, knownIds)
                        if (report.optBoolean("passed")) dryPassed++
                        val appPackage = skill.optString("appPackage", packageName)
                        val skillId = skill.optString("id", file.nameWithoutExtension)
                        val reportFile = store.saveDryRunReport(appPackage, skillId, report)
                        val factory = skill.optJSONObject("factory") ?: JSONObject()
                        factory
                            .put("dryRunStatus", if (report.optBoolean("passed")) "PASSED" else "FAILED")
                            .put("lastDryRunReport", reportFile.absolutePath)
                            .put("lastDryRunAt", System.currentTimeMillis())
                        skill.put("factory", factory)
                        if (report.optBoolean("passed")) skill.put("status", "DRY_RUN_PASSED")
                        store.saveSkill(appPackage, skill)
                    }
                    addStep("dry-run йқҷжҖҒжЈҖжҹ?, if (dryTargets.isEmpty() || dryPassed == dryTargets.size) "SUCCESS" else "FAILED_DRY_RUN", "йҖҡиҝҮ $dryPassed/${dryTargets.size}")

                    val sourceFiles = store.listSkillFiles(packageName, 1000)
                    val skills = sourceFiles
                        .mapNotNull { file -> runCatching { JSONObject(file.readText()) }.getOrNull() }
                        .filter { it.optString("status") != "REJECTED" }
                    val dryRunReports = store.listDryRunReports(packageName, 500)
                        .mapNotNull { file -> runCatching { JSONObject(file.readText()) }.getOrNull() }
                    val testReports = store.listTestReports(packageName, 500)
                        .mapNotNull { file -> runCatching { JSONObject(file.readText()) }.getOrNull() }
                    val module = AppUiModuleStore(this).loadApproved(packageName)
                        ?: AppUiModuleStore(this).listCandidates().firstOrNull { (_, candidate) -> candidate.packageName == packageName }?.second
                    val exporter = SkillJsonExporter()
                    val previewConfig = exporter.exportAppConfig(
                        packageName = packageName,
                        appName = module?.appName ?: packageName,
                        module = module,
                        skills = skills,
                        dryRunReports = dryRunReports + testReports
                    )
                    previewConfigFile = store.saveAppConfig(packageName, previewConfig)
                    val previewReport = exporter.buildAssemblyReport(
                        packageName = packageName,
                        appName = module?.appName ?: packageName,
                        approvedOnly = false,
                        sourceFiles = sourceFiles,
                        includedSkills = skills,
                        dryRunReportCount = dryRunReports.size,
                        testReportCount = testReports.size,
                        config = previewConfig,
                        previewConfigFile = previewConfigFile,
                        runtimeConfigFile = null
                    )
                    assemblyReportFile = store.saveAssemblyReport(packageName, previewReport)
                    addStep("еҜјеҮәйў„и§Ҳ app_config", "SUCCESS", previewConfigFile?.absolutePath.orEmpty())

                    val safeSkillFile = store.listSkillFiles(packageName, 1000).firstOrNull { file ->
                        runCatching {
                            val skill = JSONObject(file.readText())
                            skill.optString("kind") == "atomic_skill" &&
                                skill.optJSONObject("action")?.optString("type") == "ResolveElement"
                        }.getOrDefault(false)
                    }
                    if (safeSkillFile == null) {
                        addStep("йҖүжӢ©е®үе…ЁжөӢиҜ• skill", "FAILED_NO_SAFE_SKILL", "жІЎжңүжүҫеҲ° ResolveElement еҺҹеӯҗ skill")
                    } else {
                        var skill = JSONObject(safeSkillFile.readText())
                        testedSkillId = skill.optString("id", safeSkillFile.nameWithoutExtension)
                        addStep("йҖүжӢ©е®үе…ЁжөӢиҜ• skill", "SUCCESS", testedSkillId)

                        val runtimeAlreadyExists = store.loadRuntimeApprovedSkillById(testedSkillId) != null
                        if (!runtimeAlreadyExists && skill.optString("status") == "APPROVED") {
                            store.saveRuntimeApprovedSkill(packageName, skill)
                            addStep("иЎҘеҶҷ Runtime skill", "SUCCESS", "$testedSkillId е·ІеӨҚеҲ¶еҲ°иҝҗиЎҢзӣ®еҪ•")
                        } else if (!runtimeAlreadyExists) {
                            val testReport = SkillJsonTestRunner(this).runRepeated(
                                skill = skill,
                                params = JSONObject(),
                                runs = 10,
                                allowSideEffect = false
                            )
                            val testReportFile = store.saveTestReport(packageName, testedSkillId, testReport)
                            val factory = skill.optJSONObject("factory") ?: JSONObject()
                            factory
                                .put("testRuns", testReport.optInt("testRuns"))
                                .put("successRate", testReport.optDouble("successRate"))
                                .put("lastTestReport", testReportFile.absolutePath)
                                .put("lastTestAt", System.currentTimeMillis())
                            skill.put("factory", factory)
                            if (testReport.optDouble("successRate", 0.0) >= 0.80 && testReport.optInt("failed", 0) == 0) {
                                skill.put("status", "TEST_PASSED")
                            }
                            store.saveSkill(packageName, skill)
                            addStep("иҮӘеҠЁжөӢиҜ•", if (testReport.optInt("failed", 0) == 0) "SUCCESS" else "FAILED_TEST", "жҲҗеҠҹзұ?${testReport.optInt("success") + testReport.optInt("mediumConfidence") + testReport.optInt("lowConfidence")}/${testReport.optInt("testRuns")}")

                            val dryRunReport = latestJsonReportForSkill(store.listDryRunReports(packageName, 500), testedSkillId)
                            val decision = SkillJsonPromotionGate().evaluate(skill, dryRunReport, testReport)
                            if (decision.optBoolean("approved")) {
                                val approvedSkill = JSONObject(skill.toString())
                                    .put("status", "APPROVED")
                                    .put("approvedLevel", decision.optString("status"))
                                approvedSkill.put("factory", (approvedSkill.optJSONObject("factory") ?: JSONObject())
                                    .put("promotedAt", System.currentTimeMillis())
                                    .put("promotionStatus", decision.optString("status"))
                                    .put("promotionDecision", decision))
                                store.saveSkill(packageName, approvedSkill)
                                store.savePromotedSkill(packageName, approvedSkill)
                                store.saveRuntimeApprovedSkill(packageName, approvedSkill)
                                skill = approvedSkill
                                addStep("жҷӢзә§й—?, "SUCCESS", "${testedSkillId} -> ${factoryStatusText(decision.optString("status"))}")
                            } else {
                                addStep("жҷӢзә§й—?, "FAILED_PROMOTION", decision.optString("reason"))
                            }
                        } else {
                            addStep("жҷӢзә§й—?, "SUCCESS", "$testedSkillId е·ІеңЁ Runtime approved зӣ®еҪ•")
                        }

                        runtimeConfigFile = exportRuntimeApprovedConfigFromUi(packageName)
                        addStep("иЈ…й…Қ Runtime config", if (runtimeConfigFile != null) "SUCCESS" else "FAILED_RUNTIME_CONFIG", runtimeConfigFile?.absolutePath ?: "жІЎжңү APPROVED skill еҸҜиЈ…й…?)

                        val runtimeSkill = store.loadRuntimeApprovedSkillById(testedSkillId)
                        if (runtimeSkill == null) {
                            addStep("Runtime и°ғз”Ё", "FAILED_RUNTIME_SKILL_MISSING", "иҝҗиЎҢзӣ®еҪ•жүҫдёҚеҲ?$testedSkillId")
                        } else {
                            val (runtimeSkillFile, runtimeJson) = runtimeSkill
                            val runStarted = System.currentTimeMillis()
                            val result = SkillJsonExecutor(
                                context = this@MainActivity,
                                runtimeApprovedOnly = true
                            ).execute(runtimeJson, JSONObject(), allowSideEffect = false)
                            val runReport = JSONObject()
                                .put("schemaVersion", 1)
                                .put("kind", "skill_json_runtime_run_report")
                                .put("id", "runtime_run_${System.currentTimeMillis()}")
                                .put("skillId", testedSkillId)
                                .put("appPackage", packageName)
                                .put("engine", "skill_json_runtime")
                                .put("status", result.status)
                                .put("message", result.message)
                                .put("durationMs", System.currentTimeMillis() - runStarted)
                                .put("usedCoordinate", result.usedCoordinate)
                                .put("allowSideEffect", false)
                                .put("params", JSONObject())
                                .put("runtimeSkillFile", runtimeSkillFile.absolutePath)
                                .put("runtimeConfigFile", store.runtimeApprovedConfigFile(packageName).absolutePath)
                                .put("createdAt", System.currentTimeMillis())
                            runtimeRunReportFile = store.saveRuntimeRunReport(packageName, runReport)
                            addStep("Runtime и°ғз”Ё", if (result.status.startsWith("FAILED")) result.status else "SUCCESS", "${testedSkillId}: ${factoryStatusText(result.status)}пј?{result.message}")
                        }
                    }
                }
            } catch (error: Throwable) {
                addStep("й“ҫи·ҜејӮеёё", "FAILED_EXCEPTION", error.message ?: error.javaClass.simpleName)
            }

            val flowReport = JSONObject()
                .put("schemaVersion", 1)
                .put("kind", "skill_factory_visible_flow_report")
                .put("id", "flow_report_${System.currentTimeMillis()}")
                .put("appPackage", packageName)
                .put("status", finalStatus)
                .put("testedSkillId", testedSkillId)
                .put("durationMs", System.currentTimeMillis() - startedAt)
                .put("steps", steps)
                .put("outputs", JSONObject()
                    .put("previewConfigFile", previewConfigFile?.absolutePath)
                    .put("assemblyReportFile", assemblyReportFile?.absolutePath)
                    .put("runtimeConfigFile", runtimeConfigFile?.absolutePath)
                    .put("runtimeRunReportFile", runtimeRunReportFile?.absolutePath))
                .put("createdAt", System.currentTimeMillis())
            val flowReportFile = store.saveFlowReport(packageName, flowReport)
            factoryLiveDone("дёҖй”®е®үе…ЁжөӢиҜ•е®ҢжҲ?, finalStatus, "й“ҫи·Ҝе®ҢжҲҗпј?{factoryStatusText(finalStatus)}пјӣжӯҘйӘ?${steps.length()} дёӘгҖ?, flowReportFile.absolutePath)
        }.start()
    }

