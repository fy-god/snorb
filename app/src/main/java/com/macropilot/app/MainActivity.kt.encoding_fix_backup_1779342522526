    private fun startAccessibilityGuard(reason: String, autoOpenSettingsIfDisabled: Boolean) {
        val runId = ++accessibilityGuardRunId
        val startedAt = System.currentTimeMillis()
        var lastPublishedKey: String? = null

        fun publish(title: String, status: String, message: String) {
            val key = "$title|$status|$message"
            if (key == lastPublishedKey) return
            lastPublishedKey = key
            publishAccessibilityGuardState(title, status, message)
        }

        fun tick() {
            if (runId != accessibilityGuardRunId) return

            val connected = MacroPilotAccessibilityService.instance != null
            val enabled = isAccessibilityEnabled()
            when {
                connected -> {
                    publish(
                        "ж— йҡңзўҚе·ІиҝһжҺҘ",
                        "SUCCESS",
                        "MacroPilot Runtime е·Із»‘е®ҡпјҢеҸҜд»ҘиҜ»еҸ–иҠӮзӮ№гҖҒжү§иЎҢзӮ№еҮ?иҫ“е…ҘпјҢе№¶жҳҫзӨәжӮ¬жө®жү§иЎҢеҸҚйҰҲгҖ?
                    )
                    runPendingAccessibilityTaskIfReady()
                    return
                }

                !enabled -> {
                    val autoEnabled = tryEnableAccessibilityWithSecureSettingsIfAllowed()
                    if (autoEnabled) {
                        publish(
                            "жӯЈеңЁиҮӘеҠЁеҗҜз”Ёж— йҡңзў?,
                            "RUNNING",
                            "е·ІйҖҡиҝҮ WRITE_SECURE_SETTINGS еҶҷе…Ҙ MacroPilot ж— йҡңзўҚжҺҲжқғпјҢжӯЈеңЁзӯүеҫ…зі»з»ҹз»‘е®ҡжңҚеҠЎгҖ?
                        )
                        accessibilityGuardHandler.postDelayed({ tick() }, 700L)
                        return
                    }

                    publish(
                        "ж— йҡңзўҚиў«зі»з»ҹе…ій—ӯ",
                        "FAILED_ACCESSIBILITY_DISABLED",
                        "Android дёҚе…Ғи®ёжҷ®йҖ?App йқҷй»ҳжү“ејҖж— йҡңзўҚгҖӮе·ІжҢӮиө·еҪ“еүҚд»»еҠЎпјӣиҜ·еңЁзі»з»ҹйЎөжү“ејҖ MacroPilot RuntimeпјҢеӣһжқҘеҗҺдјҡиҮӘеҠЁз»§з»ӯгҖӮеҺҹеӣ?$reason"
                    )
                    if (autoOpenSettingsIfDisabled) {
                        openAccessibilitySettingsThrottled()
                    }
                    return
                }

                else -> {
                    val elapsed = System.currentTimeMillis() - startedAt
                    publish(
                        "зӯүеҫ…ж— йҡңзўҚжңҚеҠЎз»‘е®?,
                        "RUNNING",
                        "зі»з»ҹејҖе…іе·ІејҖеҗҜпјҢдҪҶжңҚеҠЎе®һдҫӢиҝҳжІЎиҝһдёҠгҖӮApp жӯЈеңЁзӯүеҫ…зі»з»ҹз»‘е®ҡ MacroPilot RuntimeгҖ?
                    )
                    if (elapsed < 6500L) {
                        accessibilityGuardHandler.postDelayed({ tick() }, 700L)
                    } else {
                        if (restartProcessForAccessibilityRebind("SERVICE_ENABLED_BUT_NOT_BOUND")) {
                            return
                        }
                        publish(
                            "ж— йҡңзўҚд»ҚжңӘиҝһжҺ?,
                            "FAILED_ACCESSIBILITY_DISCONNECTED",
                            "зі»з»ҹејҖе…іеғҸжҳҜејҖзқҖпјҢдҪҶ Runtime жІЎжңүз»‘е®ҡгҖӮиҜ·иҝӣе…Ҙж— йҡңзўҚи®ҫзҪ®е…ій—ӯеҶҚжү“ејҖ MacroPilot RuntimeпјҢеӣһжқҘеҗҺд»»еҠЎдјҡиҮӘеҠЁз»§з»ӯгҖ?
                        )
                        if (autoOpenSettingsIfDisabled) {
                            openAccessibilitySettingsThrottled()
                        }
                    }
                }
            }
        }

        tick()
    }

    private fun restartProcessForAccessibilityRebind(reason: String): Boolean {
        if (!hasWriteSecureSettingsPermission()) return false
        val now = System.currentTimeMillis()
        if (now - accessibilityProcessRestartedAt < 20000L) return false
        accessibilityProcessRestartedAt = now
        accessibilityRebindInProgress = true
        getSharedPreferences(ACCESSIBILITY_GUARD_PREFS, MODE_PRIVATE)
            .edit()
            .putBoolean(PREF_PENDING_ACCESSIBILITY_REBIND, true)
            .putString(PREF_PENDING_ACCESSIBILITY_REBIND_REASON, reason)
            .apply()
        publishAccessibilityGuardState(
            "ж— йҡңзўҚеҒҮејҖеҗҜпјҢиҮӘеҠЁйҮҚеҗҜйҮҚз»‘",
            "RUNNING",
            "зі»з»ҹејҖе…іе·ІејҖдҪҶжңҚеҠЎе®һдҫӢжІЎжңүз»‘е®ҡпјҢйҖҡеёёжҳ?Android жҠҠжңҚеҠЎж”ҫиҝ?Crashed servicesгҖӮApp дјҡиҮӘеҠЁйҮҚеҗҜдёҖж¬Ўе№¶йҮҚж–°еҶҷе…Ҙж— йҡңзўҚжҺҲжқғгҖ?
        )
        val restartIntent = Intent(this, MainActivity::class.java).apply {
            addFlags(Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TOP)
            putExtra("accessibility_rebind_reason", reason)
        }
        val pendingIntent = PendingIntent.getActivity(
            this,
            4208,
            restartIntent,
            PendingIntent.FLAG_UPDATE_CURRENT or PendingIntent.FLAG_IMMUTABLE
        )
        val alarmManager = getSystemService(AlarmManager::class.java)
        val triggerAt = System.currentTimeMillis() + 900L
        runCatching {
            alarmManager?.setExactAndAllowWhileIdle(AlarmManager.RTC_WAKEUP, triggerAt, pendingIntent)
        }.recoverCatching {
            alarmManager?.set(AlarmManager.RTC_WAKEUP, triggerAt, pendingIntent)
        }
        accessibilityGuardHandler.postDelayed({
            Process.killProcess(Process.myPid())
        }, 250L)
        return true
    }

    private fun consumePendingAccessibilityRebindFlag(): Boolean {
        val prefs = getSharedPreferences(ACCESSIBILITY_GUARD_PREFS, MODE_PRIVATE)
        val pending = prefs.getBoolean(PREF_PENDING_ACCESSIBILITY_REBIND, false)
        if (pending) {
            prefs.edit()
                .remove(PREF_PENDING_ACCESSIBILITY_REBIND)
                .remove(PREF_PENDING_ACCESSIBILITY_REBIND_REASON)
                .apply()
        }
        return pending
    }

    private fun scheduleAccessibilitySettingsRebind(reason: String): Boolean {
        if (!hasWriteSecureSettingsPermission()) return false
        publishAccessibilityGuardState(
            "жӯЈеңЁйҮҚеҶҷж— йҡңзўҚејҖе…?,
            "RUNNING",
            "жӯЈеңЁжё…йҷӨж—§з»‘е®ҡе№¶йҮҚж–°еҶҷе…Ҙ MacroPilot Runtimeпј?reason"
        )
        val component = accessibilityComponentName().flattenToString()
        val shortComponent = accessibilityComponentName().flattenToShortString()
        val existing = Settings.Secure.getString(
            contentResolver,
            Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES
        ).orEmpty()
            .split(":")
            .map { it.trim() }
            .filter { it.isNotBlank() }
            .filterNot {
                it.equals(component, ignoreCase = true) ||
                    it.equals(shortComponent, ignoreCase = true)
            }

        Settings.Secure.putString(
            contentResolver,
            Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES,
            existing.joinToString(":")
        )
        Settings.Secure.putString(
            contentResolver,
            Settings.Secure.ACCESSIBILITY_ENABLED,
            if (existing.isEmpty()) "0" else "1"
        )

        accessibilityGuardHandler.postDelayed({
            val refreshed = Settings.Secure.getString(
                contentResolver,
                Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES
            ).orEmpty()
                .split(":")
                .map { it.trim() }
                .filter { it.isNotBlank() }
                .toMutableList()
            if (refreshed.none {
                    it.equals(component, ignoreCase = true) ||
                        it.equals(shortComponent, ignoreCase = true)
                }
            ) {
                refreshed.add(component)
            }
            Settings.Secure.putString(
                contentResolver,
                Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES,
                refreshed.joinToString(":")
            )
            Settings.Secure.putString(contentResolver, Settings.Secure.ACCESSIBILITY_ENABLED, "1")
            accessibilityRebindInProgress = false
            startAccessibilityGuard("SECURE_SETTINGS_REBIND", autoOpenSettingsIfDisabled = true)
        }, 900L)
        return true
    }

    private fun publishAccessibilityGuardState(title: String, status: String, message: String) {
        if (status == "SUCCESS" && message.contains("MacroPilot Runtime")) {
            if ((currentTab == Tab.HOME && homeRunEvents.isNotEmpty()) ||
                (currentTab == Tab.FACTORY && factoryLiveEvents.isNotEmpty())) {
                return
            }
        }
        if (currentTab == Tab.HOME) {
            homeRunStep(title, status, message)
        } else {
            factoryLiveStep(title, status, message)
        }
    }

    private fun runPendingAccessibilityTaskIfReady() {
        if (MacroPilotAccessibilityService.instance == null) return
        val pendingFactory = pendingFactoryInstructionAfterAccessibility
        if (pendingFactory != null) {
            pendingFactoryInstructionAfterAccessibility = null
            factoryLiveStep(
                "ж— йҡңзўҚе·ІиҝһжҺҘпјҢз»§з»ӯжү§иЎ?,
                "RUNNING",
                "з»§з»ӯеҲҡжүҚжҢӮиө·зҡ„жүӢжңәз«Ҝ AI жҢҮд»Өпј?{pendingFactory.first}"
            )
            runAppSideDirectInstructionFlowFromUi(
                pendingFactory.first,
                pendingFactory.second,
                skipAccessibilityPrecheck = true
            )
            return
        }

        val pendingHome = pendingHomeCommandAfterAccessibility
        if (pendingHome != null) {
            pendingHomeCommandAfterAccessibility = null
            homeRunStep(
                "ж— йҡңзўҚе·ІиҝһжҺҘпјҢз»§з»ӯжү§иЎ?,
                "RUNNING",
                "з»§з»ӯеҲҡжүҚжҢӮиө·зҡ„дё»йЎөйқўжҢҮд»Өпј?pendingHome"
            )
            runUserCommand(pendingHome, skipAccessibilityPrecheck = true)
        }
    }

    private fun ensureAccessibilityForFactoryRun(instruction: String, packageHint: String): Boolean {
        if (MacroPilotAccessibilityService.instance != null) return true
        pendingFactoryInstructionAfterAccessibility = instruction to packageHint
        factoryLiveStart(
            packageHint.ifBlank { "__ai_decides__" },
            "зӯүеҫ…ж— йҡңзўҚиҝһжҺ?,
            "д»»еҠЎе·ІжҢӮиө·пјҢжІЎжңүж— йҡңзўҚе°ұдёҚиғҪжҗңзҙўгҖҒзӮ№еҮ»гҖҒзӮ№иөһжҲ–иҜ„и®әгҖӮиҝһжҺ?MacroPilot Runtime еҗҺдјҡиҮӘеҠЁз»§з»ӯпј?instruction"
        )
        startAccessibilityGuard("FACTORY_TASK_PRECHECK", autoOpenSettingsIfDisabled = true)
        return false
    }

    private fun ensureAccessibilityForHomeRun(command: String): Boolean {
        if (MacroPilotAccessibilityService.instance != null) return true
        pendingHomeCommandAfterAccessibility = command
        homeRunStart(
            "зӯүеҫ…ж— йҡңзўҚиҝһжҺ?,
            "д»»еҠЎе·ІжҢӮиө·пјҢжІЎжңүж— йҡңзўҚе°ұдёҚиғҪзңҹе®һжҺ§еҲ¶жүӢжңәгҖӮиҝһжҺ?MacroPilot Runtime еҗҺдјҡиҮӘеҠЁз»§з»ӯпј?command"
        )
        startAccessibilityGuard("HOME_TASK_PRECHECK", autoOpenSettingsIfDisabled = true)
        return false
    }

    private fun openAccessibilitySettingsThrottled() {
        val now = System.currentTimeMillis()
        if (now - accessibilitySettingsPromptedAt < 15000L) return
        accessibilitySettingsPromptedAt = now
        runCatching {
            startActivity(Intent(Settings.ACTION_ACCESSIBILITY_SETTINGS))
        }.onFailure {
            publishAccessibilityGuardState(
                "ж— жі•жү“ејҖж— йҡңзўҚи®ҫзҪ?,
                "FAILED_EXCEPTION",
                it.message ?: it.javaClass.simpleName
            )
        }
    }

    private fun tryEnableAccessibilityWithSecureSettingsIfAllowed(): Boolean {
        if (!hasWriteSecureSettingsPermission()) return false
        return runCatching {
            val component = accessibilityComponentName().flattenToString()
            val shortComponent = accessibilityComponentName().flattenToShortString()
            val enabledRaw = Settings.Secure.getString(
                contentResolver,
                Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES
            ).orEmpty()
            val services = enabledRaw
                .split(":")
                .map { it.trim() }
                .filter { it.isNotBlank() }
                .toMutableList()
            val alreadyPresent = services.any {
                it.equals(component, ignoreCase = true) ||
                    it.equals(shortComponent, ignoreCase = true)
            }
            if (!alreadyPresent) services.add(component)
            Settings.Secure.putString(
                contentResolver,
                Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES,
                services.joinToString(":")
            )
            Settings.Secure.putString(contentResolver, Settings.Secure.ACCESSIBILITY_ENABLED, "1")
            isAccessibilityEnabled()
        }.getOrDefault(false)
    }

    private fun hasWriteSecureSettingsPermission(): Boolean {
        return checkCallingOrSelfPermission("android.permission.WRITE_SECURE_SETTINGS") ==
            PackageManager.PERMISSION_GRANTED
    }

    private fun accessibilityComponentName(): ComponentName {
        return ComponentName(packageName, MacroPilotAccessibilityService::class.java.name)
    }

    private fun isAccessibilityEnabled(): Boolean {
        val globalEnabled = Settings.Secure.getString(
            contentResolver,
            Settings.Secure.ACCESSIBILITY_ENABLED
        ) == "1"
        val enabled = Settings.Secure.getString(
            contentResolver,
            Settings.Secure.ENABLED_ACCESSIBILITY_SERVICES
        ) ?: return false
        val expected = accessibilityComponentName().flattenToString()
        val flattenedShort = accessibilityComponentName().flattenToShortString()
        val serviceListed = enabled.split(":").any {
            it.equals(expected, true) || it.equals(flattenedShort, true)
        }
        return globalEnabled && serviceListed
    }

