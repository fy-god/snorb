    private fun parseAiProvider(raw: String): AiProvider {
        val normalized = raw.trim().uppercase()
            .replace("-", "_")
            .replace(" ", "_")
        return when (normalized) {
            "", "QWEN", "TONGYI", "DASHSCOPE", "DASHSCOPE_COMPAT", "DASHSCOPE_COMPATIBLE", "QWEN_VL" ->
                AiProvider.DASHSCOPE_COMPAT_CHAT
            "DEEPSEEK", "OPENAI_COMPAT", "OPENAI_COMPATIBLE", "OPENAI_COMPATIBLE_CHAT", "CHAT_COMPLETIONS" ->
                AiProvider.OPENAI_COMPAT_CHAT
            else -> runCatching { AiProvider.valueOf(normalized) }.getOrDefault(AiProvider.DASHSCOPE_COMPAT_CHAT)
        }
    }

