                .put("id", "factory_ai_connection_${System.currentTimeMillis()}")
                .put("taskType", "CONNECTION_TEST")
                .put("appPackage", factoryTargetPackage)
                .put("relatedTraceIds", org.json.JSONArray())
                .put("relatedSampleIds", org.json.JSONArray())
                .put("relatedCandidateIds", org.json.JSONArray())
                .put("createdAt", System.currentTimeMillis())
                .put("durationMs", System.currentTimeMillis() - startedAt)
                .put("inputSummary", "AI жҺҘеҸЈиҝһжҺҘжөӢиҜ•")
                .put("promptSnapshot", JSONObject().put("task", "connection_test"))
                .put("aiStatus", response.status.name)
                .put("aiMessage", response.message)
                .put("provider", response.provider?.name ?: config.provider.name)
                .put("httpStatus", response.httpStatus)
                .put("model", config.model)
