        val filterRow = horizontal()
        val filterInput = EditText(this).apply {
            hint = "жҗңзҙўеә”з”ЁжҲ–еҢ…еҗ?
            setText(appFilter)
            textSize = 14f
            setSingleLine(true)
            setTextColor(COLOR_TEXT)
            setHintTextColor(COLOR_DIM)
            background = rounded(COLOR_FIELD, dp(8), COLOR_STROKE)
