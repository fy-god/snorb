    private fun updateFactoryLive(
        packageName: String,
        title: String,
        status: String,
        message: String,
        path: String?,
        reset: Boolean
    ) {
        val applyUpdate = {
            factoryLivePackage = packageName.ifBlank { factoryTargetPackage }
            factoryLiveTitle = title
            factoryLiveStatus = status
            factoryLiveMessage = message
            factoryLivePath = if (reset) path else path ?: factoryLivePath
            val event = FactoryLiveEvent(
                timestamp = System.currentTimeMillis(),
                title = title,
                status = status,
                message = message,
                path = path
            )
            factoryLiveEvents = if (reset) {
                listOf(event)
            } else {
                (listOf(event) + factoryLiveEvents).take(40)
            }
            if (currentTab == Tab.FACTORY) renderFactoryV2()
        }
        if (Looper.myLooper() == Looper.getMainLooper()) {
            applyUpdate()
        } else {
            runOnUiThread { applyUpdate() }
        }
    }

