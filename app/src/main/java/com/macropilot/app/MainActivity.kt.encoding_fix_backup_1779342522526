                message = "AI зҠ¶жҖ?${factoryStatusText(result.aiStatus)}пјӣз”ҹжҲ?${result.candidateFiles.size} дёӘеҖҷйҖүиғҪеҠӣпјӣAI Job=${result.jobFile.name}гҖ?,
                path = path
            )
            if (result.candidateFiles.isNotEmpty()) {
                val packageForExport = result.intentDraft.optString("appPackage").ifBlank { packageName }
                val export = exportPreviewAppConfigNow(packageForExport)
                factoryLiveDone(
                    title = "еҖҷйҖүе·ІжӢјжҲҗйў„и§Ҳ app_config",
