    private fun runUserCommand(command: String, skipAccessibilityPrecheck: Boolean = false) {
        val cleaned = command.trim()
        if (cleaned.isBlank()) {
            homeRunDone("жІЎжңүжү§иЎҢ", "FAILED_PRECONDITION", "иҜ·е…Ҳиҫ“е…Ҙд»»еҠЎгҖӮзӨәдҫӢпјҡжҗңзҙўи®ҫзҪ® WLAN")
            return
        }
        if (!skipAccessibilityPrecheck && !ensureAccessibilityForHomeRun(cleaned)) {
            return
        }
        if (!isSettingsSearchCommand(cleaned)) {
            factoryInstruction = cleaned
            val target = inferPackageForUiCommand(cleaned)
            homeRunStart("AI зӣҙжҺҘжү§иЎҢз”ЁжҲ·жҢҮд»Ө", "дё»иҫ“е…Ҙе·ІжҺҘеҲ°жүӢжңәз«?AI жү§иЎҢеҷЁпјҡдјҡз”ҹжҲ?Skill JSONгҖҒdry-runгҖҒжӢј app_configпјҢе№¶зӣҙжҺҘжү§иЎҢеҖҷйҖ?JSONгҖ?)
            Thread {
                val report = AppSideInstructionFlowRunner(this@MainActivity) { event ->
                    homeRunStep(event.title, event.status, event.message, event.path)
                }.runInstructionFlow(cleaned, target)
                val reportPackage = report.optString("appPackage").ifBlank { target }
                if (reportPackage.isNotBlank()) factoryTargetPackage = reportPackage
                homeRunDone(
                    title = "з”ЁжҲ·жҢҮд»Өжү§иЎҢе®ҢжҲҗ",
                    status = report.optString("status", "SUCCESS"),
                    message = "жӯҘйӘӨ=${report.optJSONArray("steps")?.length() ?: 0}пјӣAI/JSON/жү§иЎҢжҠҘе‘ҠйғҪе·ІеҶҷе…ҘиҜҒжҚ®й“ҫгҖ?,
                    path = report.optString("reportFile")
                )
            }.start()
            return
        }
        val query = settingsSearchQuery(cleaned)

        homeRunStart("еҮҶеӨҮжү§иЎҢи®ҫзҪ®жҗңзҙў", "Runtime е°ҶеҠ иҪҪе·ІжҷӢзә§и®ҫзҪ®зӨәдҫӢиғҪеҠӣпјҢжҹҘиҜўпјҡ$query")
        Thread {
            seedAllSettingsSkills()
            homeRunStep("е®үиЈ…/еҲ·ж–°зӨәдҫӢиғҪеҠӣ", "SUCCESS", "е·ІзЎ®дҝ?settings_search жҳ?APPROVED зӨәдҫӢиғҪеҠӣгҖ?)
            homeRunStep("еҠ иҪҪиҝҗиЎҢзҹҘиҜҶ", "RUNNING", "жӯЈеңЁиҜ»еҸ– AppUiModule е’?MacroTemplateгҖ?)
            val appUi = AppUiModuleStore(this).loadApproved(BuiltinKnowledgeSeeder.SETTINGS_PACKAGE)
            val template = MacroTemplateStore(this).loadApproved(BuiltinKnowledgeSeeder.SETTINGS_SEARCH_TEMPLATE_ID)
            if (appUi == null || template == null) {
                homeRunDone("еҠ иҪҪеӨұиҙҘ", "FAILED_PRECONDITION", "missing approved knowledge")
            } else {
                val startedAt = System.currentTimeMillis()
                homeRunStep("ејҖе§Ӣжү§иЎ?, "RUNNING", "жӯЈеңЁжү“ејҖи®ҫзҪ®е№¶жҗңзҙўпјҡ$query")
                val result = MacroExecutor(NodeInspector(this), CapabilityProfiler(), DeviceActions(this))
                    .execute(template, appUi, mapOf("query" to query))
                val durationMs = System.currentTimeMillis() - startedAt
                val reportFile = RunLogStore(this).save(template.id, result, durationMs, "ui_command=$cleaned")
                homeRunDone(
                    title = "жү§иЎҢе®ҢжҲҗ",
                    status = result.status.name,
                    message = "${localizeRuntimeMessage(result.message)}пјӣзҪ®дҝ?${result.confidence.name}пјӣиҖ—ж—¶ ${durationMs}msгҖ?,
                    path = reportFile.absolutePath
                )
            }
        }.start()
    }

    private fun isSettingsSearchCommand(command: String): Boolean {
        val normalized = command.trim()
        return normalized.contains("жҗңзҙўи®ҫзҪ®") ||
            normalized.contains("жҗңи®ҫзҪ?) ||
            normalized.contains("и®ҫзҪ®жҗңзҙў") ||
            normalized.equals("WLAN", ignoreCase = true) ||
            normalized.equals("WiFi", ignoreCase = true) ||
            normalized.equals("Wi-Fi", ignoreCase = true)
    }

    private fun settingsSearchQuery(command: String): String {
        return command
            .replace("жҗңзҙўи®ҫзҪ®", "")
            .replace("жҗңи®ҫзҪ?, "")
            .replace("и®ҫзҪ®жҗңзҙў", "")
            .replace("жҗңзҙў", "")
            .trim()
            .ifBlank { "WLAN" }
    }

