    @Suppress("DEPRECATION")
    private fun loadInstalledApps(): List<AppEntry> {
        val intent = Intent(Intent.ACTION_MAIN).addCategory(Intent.CATEGORY_LAUNCHER)
        val pm = packageManager
        val approvedPackages = AppUiModuleStore(this).listApproved()
            .flatMap { listOf(it.packageName) + it.packageAliases }
            .toSet()
        val launcherPackages = pm.queryIntentActivities(intent, 0)
            .map { it.activityInfo.packageName }
            .toSet()

        return pm.getInstalledPackages(0)
            .mapNotNull { info ->
                val appInfo = info.applicationInfo ?: return@mapNotNull null
                val pkg = info.packageName
                val launchable = pkg in launcherPackages
                val system = (appInfo.flags and ApplicationInfo.FLAG_SYSTEM) != 0
                AppEntry(
                    label = runCatching { appInfo.loadLabel(pm).toString() }.getOrDefault(pkg),
                    packageName = pkg,
                    version = info.versionName.orEmpty(),
                    icon = runCatching { appInfo.loadIcon(pm) }.getOrDefault(pm.defaultActivityIcon),
                    launchable = launchable,
                    system = system,
                    priority = when {
                        pkg in approvedPackages -> 0
                        launchable && !system -> 1
                        !system -> 2
                        launchable -> 3
                        else -> 4
                    }
                )
            }
            .distinctBy { it.packageName }
            .sortedWith(compareBy<AppEntry> { it.priority }.thenBy { it.label.lowercase() })
    }

    private fun filterApps(apps: List<AppEntry>): List<AppEntry> {
        val query = appFilter.trim()
        if (query.isBlank()) return apps
        return apps.filter {
            it.label.contains(query, ignoreCase = true) ||
                it.packageName.contains(query, ignoreCase = true)
        }
    }

    private fun scopeApps(
        apps: List<AppEntry>,
        modules: List<AppUiModule>,
        skills: List<MacroTemplate>,
        jsonSkillPackages: Set<String> = emptySet()
    ): List<AppEntry> {
        val modulePackages = modules
            .flatMap { listOf(it.packageName) + it.packageAliases }
            .toSet()
        val skillPackages = skills.map { it.packageName }.toSet() + jsonSkillPackages
        val skillOwners = modules
            .filter { it.packageName in skillPackages }
            .flatMap { listOf(it.packageName) + it.packageAliases }
            .toSet() + skillPackages
        return when (appScope) {
            AppScope.ALL -> apps
            AppScope.MODULES -> apps.filter { it.packageName in modulePackages }
            AppScope.SKILLS -> apps.filter { it.packageName in skillOwners }
        }
    }

