    private fun importantFlowStageSummaryClean(steps: JSONArray?): String {
        if (steps == null || steps.length() == 0) return "иҝҳжІЎжңүжӯҘйӘӨгҖ?
        val stages = listOf(
            "AppUI" to listOf("AppUI"),
            "AI" to listOf("AI/и§„еҲҷ", "AI"),
            "иЎҘдёҒжӢјиЈ…" to listOf("ж”№еҶҷ", "жӢјиЈ…", "жЁЎжқҝ", "Skill"),
            "dry-run" to listOf("dry-run"),
            "app_config" to listOf("жӢјиЈ…", "иЈ…й…Қ"),
            "жөӢиҜ•" to listOf("жөӢиҜ•жҠҘе‘Ҡ"),
            "жҷӢзә§й—? to listOf("PromotionGate"),
            "Runtime" to listOf("Runtime и°ғз”Ё")
        )
        return stages.joinToString(" / ") { (name, keywords) ->
            val step = latestStepMatchingClean(steps, keywords)
            if (step == null) "$name=жңӘеҲ°" else "$name=${factoryStatusTextClean(step.optString("status"))}"
        }
    }

    private fun latestStepMatchingClean(steps: JSONArray, keywords: List<String>): JSONObject? {
        for (index in steps.length() - 1 downTo 0) {
            val step = steps.optJSONObject(index) ?: continue
            val title = step.optString("title")
            if (keywords.any { title.contains(it, ignoreCase = true) }) return step
        }
        return null
    }

